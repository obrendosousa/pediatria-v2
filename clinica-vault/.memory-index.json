{"version":1,"built_at":"2026-03-23T23:37:47.521Z","entries":[{"slug":"feedback_melhoria/padrao-evasao-de-pacientes-por-falta-de-vaga-imediata-urgencia-frequenc","path":"C:\\Users\\Brendo\\Documents\\pediatria-v2\\clinica-vault\\memories\\feedback_melhoria\\padrao-evasao-de-pacientes-por-falta-de-vaga-imediata-urgencia-frequenc.md","content":"**Padrão:** Evasão de pacientes por falta de vaga imediata (urgência)\n**Frequência:** Alta — Média de 25 pacientes perdidos por semana.\n**Observação:** Pacientes com alta intenção de fechamento buscam a clínica para casos urgentes, mas desistem por falta de encaixe na agenda.\n**Impacto financeiro/operacional:** Perda estimada de R$ 12.500/semana (R$ 50.000/mês), projetando um sangramento de mais de R$ 146 mil apenas no primeiro trimestre de 2026.\n**Ação recomendada:** Priorizar suporte operacional à secretária (Joana) para otimizar a gestão de encaixes e fila de espera diária.","memory_type":"feedback_melhoria","quality_score":100,"connections":[],"updated_at":"2026-03-23T23:37:47.520Z"}],"embeddings":{"feedback_melhoria/padrao-evasao-de-pacientes-por-falta-de-vaga-imediata-urgencia-frequenc":[-0.0043182587,0.0020811714,-0.0042780535,-0.060713153,-0.010829136,-0.010285351,-0.029792955,-0.0037642797,-0.01000799,0.016135344,-0.0007852121,0.0004140003,-0.007998386,-0.0049061305,0.117511734,0.024195217,0.0084808525,0.016822396,0.010884306,0.00022219743,0.011651158,0.013446267,-0.027937053,-0.030605651,-0.008426048,-0.018914817,0.032694496,-0.005551064,0.048208967,0.017897211,-0.0050754766,-0.019533858,0.027032325,0.006770275,0.004028842,0.01595569,0.019362004,0.006607806,0.0033767615,0.02383313,0.022018116,-0.0016881104,0.005479043,0.00007695777,0.004600186,0.015427893,-0.01285886,-0.03600371,-0.0006589102,0.007560179,-0.0033364485,0.0067714313,-0.030631585,-0.15466122,-0.007803636,-0.022666654,0.029428847,0.0005281763,0.019936066,-0.012036056,-0.020910688,0.030721499,0.024845436,-0.0038712267,0.0060542864,-0.012062559,0.007744