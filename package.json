{
  "name": "painel-clinica",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20"
  },
  "scripts": {
    "dev": "node scripts/dev-with-webhook.mjs",
    "dev:next": "next dev",
    "worker:dev": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config worker/src/main.ts",
    "worker:start": "DOTENV_CONFIG_PATH=.env.local node --require dotenv/config --enable-source-maps ./node_modules/tsx/dist/cli.mjs worker/src/main.ts",
    "worker:dry-run": "DOTENV_CONFIG_PATH=.env.local tsx -r dotenv/config worker/src/dry-run.ts",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' next build",
    "start": "next start",
    "lint": "eslint",
    "test:crm-metrics": "node --test --import tsx src/lib/crm/metrics.test.ts",
    "seed:growth": "tsx scripts/seed_growth_data.ts",
    "postinstall": "echo '✅ Dependências instaladas com sucesso!'",
    "git:commit": "node git-commit.mjs",
    "git:push": "node git-push.mjs",
    "tts": "cd src/ai/voice && source .venv/bin/activate && python server.py",
    "backfill-memories": "npx tsx --env-file=.env.local scripts/backfill-memory-embeddings.mts",
    "vault:mcp": "npx tsx --env-file=.env.local src/ai/vault/mcp-server.ts",
    "vault:watch": "npx tsx --env-file=.env.local src/ai/vault/file-watcher.ts",
    "vault:migrate": "npx tsx --env-file=.env.local scripts/migrate-to-vault.ts",
    "memory:cleanup": "npx tsx --env-file=.env.local scripts/cleanup-memories.mts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^1.46.0",
    "@hookform/resolvers": "^5.2.2",
    "@internationalized/date": "^3.12.0",
    "@langchain/community": "^1.1.20",
    "@langchain/core": "^1.1.28",
    "@langchain/google-genai": "^2.1.20",
    "@langchain/langgraph": "^1.1.4",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.0",
    "@langchain/openai": "^1.2.10",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@number-flow/react": "^0.6.0",
    "@radix-ui/react-icons": "^1.3.2",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.89.0",
    "@tiptap/extension-color": "^3.20.1",
    "@tiptap/extension-font-family": "^3.20.1",
    "@tiptap/extension-heading": "^3.20.1",
    "@tiptap/extension-highlight": "^3.20.1",
    "@tiptap/extension-image": "^3.20.1",
    "@tiptap/extension-link": "^3.20.1",
    "@tiptap/extension-placeholder": "^3.20.1",
    "@tiptap/extension-table": "^3.20.1",
    "@tiptap/extension-table-cell": "^3.20.1",
    "@tiptap/extension-table-header": "^3.20.1",
    "@tiptap/extension-table-row": "^3.20.1",
    "@tiptap/extension-text-align": "^3.20.1",
    "@tiptap/extension-text-style": "^3.20.1",
    "@tiptap/extension-underline": "^3.20.1",
    "@tiptap/pm": "^3.20.1",
    "@tiptap/react": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "bullmq": "^5.70.1",
    "chokidar": "^5.0.0",
    "date-fns": "^4.1.0",
    "emoji-picker-react": "^4.16.1",
    "framer-motion": "^12.38.0",
    "gray-matter": "^4.0.3",
    "html2canvas": "^1.4.1",
    "ioredis": "^5.9.3",
    "jspdf": "^4.2.0",
    "kokoro-js": "^1.2.1",
    "lucide-react": "^0.562.0",
    "next": "16.0.10",
    "node-cron": "^4.2.1",
    "onnxruntime-node": "^1.24.2",
    "openai": "^6.16.0",
    "pdfjs-dist": "^5.5.207",
    "pg": "^8.19.0",
    "qrcode.react": "^4.2.0",
    "react": "19.2.1",
    "react-aria-components": "^1.16.0",
    "react-dom": "19.2.1",
    "react-hook-form": "^7.71.1",
    "react-markdown": "^10.1.0",
    "react-zxing": "^1.1.3",
    "recharts": "^3.6.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tavily": "^1.0.2",
    "wavesurfer.js": "^7.12.1",
    "xlsx": "^0.18.5",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.23",
    "babel-plugin-react-compiler": "1.0.0",
    "baseline-browser-mapping": "^2.10.16",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "isomorphic-git": "^1.36.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
